# API Configuration
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
SCREENER_SOURCE=orion  # orion or binance
BINANCE_MODE=binance_vision  # futures, spot, binance_us, or binance_vision

ORION_API_KEY=your_orion_api_key_here
ORION_API_URL=https://screener.orionterminal.com/api/screener

BITUNIX_API_KEY=your_bitunix_api_key_here
BITUNIX_API_SECRET=your_bitunix_api_secret_here

# Trading Configuration
TRADING_MODE=paper  # paper or live
RISK_PER_TRADE=0.01  # 1% risk per trade
MAX_POSITIONS=3
SCREENER_QUOTE_CURRENCY=USDT
MIN_VOLUME_5M=100000  # Minimum 5-minute volume in USD (lower = more altcoins, higher = fewer but more active)
